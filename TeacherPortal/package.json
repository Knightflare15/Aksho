{
  "name": "the-script-teacher-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "npm run test:subscription",
    "test:subscription": "tsc -p tsconfig.subscription-tests.json && node --test .test-dist/tests/subscriptionProvider.test.js",
    "preview": "vite preview",
    "content:validate": "node ../Tools/ValidateProductionContent.mjs",
    "loc:report": "node ../Tools/CheckSourceLoc.mjs",
    "loc:check": "node ../Tools/CheckSourceLoc.mjs --check",
    "firebase:login": "firebase login",
    "firebase:use": "firebase use --add",
    "firebase:emulators": "firebase emulators:start",
    "firebase:deploy": "npm run build && npm --prefix functions run build && firebase deploy --only hosting,firestore,functions",
    "firebase:deploy:spark": "npm run build && firebase deploy --only hosting,firestore",
    "firebase:deploy:hosting": "npm run build && firebase deploy --only hosting"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "firebase": "^12.16.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "firebase-tools": "^15.23.0",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "@opentelemetry/core": "^2.8.0",
    "uuid": "^11.1.1"
  }
}
