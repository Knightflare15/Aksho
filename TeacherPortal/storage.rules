rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function sameSchool(schoolId) {
      return signedIn() && profile().schoolId == schoolId;
    }

    function isStudentSelf(schoolId, studentId) {
      return sameSchool(schoolId)
        && profile().role == "student"
        && profile().studentId == studentId;
    }

    match /schools/{schoolId}/students/{studentId}/pronunciationAudio/{fileName} {
      // Audio is a transient server-processing object, not a teacher/student archive.
      // Cloud Functions Admin SDK bypasses rules and deletes it after assessment.
      allow read: if false;
      allow create: if isStudentSelf(schoolId, studentId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType == "audio/wav";
      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
