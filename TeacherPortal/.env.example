# Firebase browser configuration (public project identifiers, never Admin SDK secrets)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_APPCHECK_SITE_KEY=
VITE_FIREBASE_WORKFLOW=spark

# Optional public price labels. The hosted billing page remains the price source of truth.
VITE_PRICE_INDIVIDUAL_LABEL=₹399
VITE_PRICE_EDUCATOR_LABEL=₹899
VITE_PRICE_SCHOOL_LABEL=Let's talk

# Hosted checkout adapter. These are public destinations, not billing API secrets.
# Leave VITE_BILLING_PROVIDER unset until verified links and server-side entitlement handling exist.
VITE_BILLING_PROVIDER=hosted-checkout
VITE_BILLING_INDIVIDUAL_CHECKOUT_URL=https://billing.example.com/individual
VITE_BILLING_EDUCATOR_CHECKOUT_URL=https://billing.example.com/educator
VITE_BILLING_SCHOOL_CONTACT_URL=mailto:sales@example.com
