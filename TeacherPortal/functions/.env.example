# Azure subscription credentials are Firebase Secret Manager values:
# AZURE_SPEECH_KEY=<Azure Speech subscription key>
# SARVAM_API_KEY=<Sarvam API subscription key>
# LIVEKIT_API_KEY=<LiveKit project API key>
# LIVEKIT_API_SECRET=<LiveKit project API secret>
AZURE_SPEECH_REGION=centralindia
AZURE_SPEECH_LANGUAGE=en-US
AZURE_PRONUNCIATION_ENABLED=true
PRONUNCIATION_FUNCTION_REGION=asia-south1
PRONUNCIATION_FUNCTION_CONCURRENCY=4
PRONUNCIATION_FUNCTION_MAX_INSTANCES=5
PRONUNCIATION_REST_MAX_ATTEMPTS=3
PRONUNCIATION_REST_TIMEOUT_MS=12000
PRONUNCIATION_PROCESSING_LEASE_MS=90000

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_AGENT_NAME=buddy-voice
BUDDY_VOICE_FUNCTION_REGION=asia-south1
BUDDY_VOICE_MAX_SESSION_SECONDS=600
BUDDY_VOICE_MAX_CONCURRENT_PER_SCHOOL=100
BUDDY_VOICE_ROOM_EMPTY_TIMEOUT_SECONDS=45
BUDDY_VOICE_ROOM_DEPARTURE_TIMEOUT_SECONDS=20
BUDDY_VOICE_TOKEN_FUNCTION_CONCURRENCY=40
BUDDY_VOICE_TOKEN_FUNCTION_MAX_INSTANCES=10
BUDDY_VOICE_ENFORCE_APP_CHECK=true
BUDDY_VOICE_FREE_DAILY_SESSIONS=4
BUDDY_VOICE_STANDARD_DAILY_SESSIONS=12
BUDDY_VOICE_PREMIUM_DAILY_SESSIONS=30

BUDDY_LLM_PROVIDER=sarvam
BUDDY_ALLOW_LEGACY_CALLABLE=true
SARVAM_BUDDY_MODEL=sarvam-105b
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=codemix
GEMINI_BUDDY_MODEL=gemini-3.1-flash-lite
TEACHER_ASSISTANT_MODEL=gemini-3.1-flash-lite
TEACHER_ASSISTANT_ENABLED=true
TEACHER_ASSISTANT_VERIFIER_ENABLED=true
TEACHER_SEMANTIC_INDEX_ENABLED=false
TEACHER_SEMANTIC_EMBEDDING_MODEL=gemini-embedding-001
TEACHER_SEMANTIC_EMBEDDING_DIMENSIONS=768
GEMINI_INPUT_USD_PER_MILLION_TOKENS=0.25
GEMINI_OUTPUT_USD_PER_MILLION_TOKENS=1.50
