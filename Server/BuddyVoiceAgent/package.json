{
  "name": "the-script-buddy-voice-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/agent.js dev",
    "start": "node dist/agent.js start",
    "download-files": "livekit-agents download-files",
    "test": "npm run build && node --test dist/tests",
    "test:loop": "npm run build && node dist/test-loop.js",
    "test:replay-wavs": "npm run build && node dist/replay-wav-gate.js",
    "test:conversations": "npm run build && node dist/conversation-loop.js",
    "eval:grounding": "npm run build && node dist/grounding-quality-eval.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@livekit/agents": "1.5.2",
    "@livekit/agents-plugin-openai": "1.5.2",
    "@livekit/agents-plugin-sarvam": "1.5.2",
    "@livekit/agents-plugin-silero": "1.5.2",
    "@livekit/protocol": "1.49.0",
    "@livekit/rtc-node": "^0.13.31",
    "dotenv": "^16.6.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "typescript": "^5.9.2"
  }
}
