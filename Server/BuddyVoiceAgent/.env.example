# LiveKit worker connection. Keep secrets in the deployment secret store.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=buddy-voice

# Sarvam supplies streaming STT, streaming chat completions, and streaming TTS.
SARVAM_API_KEY=
SARVAM_VOICE_MODEL=sarvam-105b
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_LANGUAGE=unknown
SARVAM_STT_MODE=codemix
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_LANGUAGE=hi-IN

# Latency tuning. Values are deliberately conservative first-pass defaults.
BUDDY_VAD_ACTIVATION_THRESHOLD=0.50
BUDDY_VAD_MIN_SPEECH_MS=120
BUDDY_VAD_MIN_SILENCE_MS=360
BUDDY_VAD_PREFIX_PADDING_MS=240
BUDDY_TTS_MIN_BUFFER_CHARS=24
BUDDY_TTS_MAX_CHUNK_CHARS=140
BUDDY_TTS_MIN_CHUNK_WORDS=3
BUDDY_ENDPOINT_MIN_DELAY_MS=360
BUDDY_ENDPOINT_MAX_DELAY_MS=1100

# Per-replica admission and graceful-drain controls. Deploy several replicas
# with the same LIVEKIT_AGENT_NAME; LiveKit assigns each room to one replica.
BUDDY_MAX_ACTIVE_SESSIONS=8
BUDDY_IDLE_PROCESSES=4
BUDDY_DRAIN_TIMEOUT_MS=840000
BUDDY_JOB_MEMORY_WARN_MB=768
BUDDY_JOB_MEMORY_LIMIT_MB=1024
