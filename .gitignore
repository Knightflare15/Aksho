# Public, code-only repository: start by ignoring the entire Unity project.
# Only custom gameplay logic, AI/backend source, development tools, and docs are allowed.
/*
!/.gitignore
!/README.md
!/CODEBASE_GUIDE.md
!/UNITY_PRODUCTION_SETUP.md
!/BUDDY_DATA_CONTRACT.md
!/AKSHO_OUTCOME_AUDIT.md
!/PRODUCTION_READINESS_REPORT.md

# Technical design and operations documentation.
!/Docs/
!/Docs/**/*.md

# Unity: custom gameplay/application C# only. No scenes, prefabs, art, audio,
# models, ML weights, .meta files, packages, project settings, or editor state.
!/Assets/
/Assets/*
!/Assets/Scripts/
/Assets/Scripts/**
!/Assets/Scripts/**/
!/Assets/Scripts/**/*.cs

# AI and speech service source only; never model weights, logs, or dependencies.
!/Server/
/Server/*
!/Server/WavLMWorker/
/Server/WavLMWorker/*
!/Server/WavLMWorker/app/
!/Server/WavLMWorker/app/*.py
!/Server/WavLMWorker/tests/
!/Server/WavLMWorker/tests/*.py
!/Server/WavLMWorker/Dockerfile
!/Server/WavLMWorker/requirements.txt
!/Server/WavLMWorker/README.md
!/Server/WavLMWorker/run-local-tts-worker.ps1
!/Server/BuddyVoiceAgent/
/Server/BuddyVoiceAgent/*
!/Server/BuddyVoiceAgent/src/
!/Server/BuddyVoiceAgent/src/**/*.ts
!/Server/BuddyVoiceAgent/Dockerfile
!/Server/BuddyVoiceAgent/package.json
!/Server/BuddyVoiceAgent/package-lock.json
!/Server/BuddyVoiceAgent/tsconfig.json
!/Server/BuddyVoiceAgent/README.md

# Teacher portal, Firebase Functions, and LLM orchestration source.
!/TeacherPortal/
/TeacherPortal/*
!/TeacherPortal/src/
!/TeacherPortal/src/**
!/TeacherPortal/tests/
!/TeacherPortal/tests/**
!/TeacherPortal/functions/
